module

public import EvmSemantics.Crypto.Weierstrass
public import EvmSemantics.Crypto.Fp2
public import EvmSemantics.Crypto.Fp6
public import EvmSemantics.Crypto.Fp12
public import EvmSemantics.Crypto.G2

/-!
`EvmSemantics.Crypto.Bn254` ÔÇö the alt_bn128 / BN254 curve constants
plus concrete `Fp := Fin p` / `Curve p` bindings.

BN254 is the short-Weierstrass curve `y┬▓ = x┬│ + 3` (mod `p`) ÔÇö the
pairing-friendly curve Ethereum uses for the Byzantium-era zkSNARK
precompiles ECADD (0x06), ECMUL (0x07), and ECPAIRING (0x08). It is
generated by a single BarretoÔÇôNaehrig parameter `u`; every other
constant on this page is a low-degree polynomial in `u`.

Ties to the tower fields (`Fp2 Ôćĺ Fp6 Ôćĺ Fp12`, in their own modules):
each tower level pins its coefficients to `Fin Bn254.p`, so no
runtime modulus needs to be threaded through ÔÇö the type carries it.
-/

@[expose] public section

namespace EvmSemantics.Crypto.Bn254

/-- The BN family parameter `u`. Every other BN254 constant is a
    polynomial in `u`, per BarretoÔÇôNaehrig (2005). BN254 uses
    `u = 4965661367192848881` (`Ôëł 2ÔüÂ┬▓`), chosen so that both the
    field prime and the group order below are prime. -/
def u : Nat := 4965661367192848881

/-- BN254 base-field prime `p = 36uÔü┤ + 36u┬│ + 24u┬▓ + 6u + 1`
    (Ôëł 2┬▓ÔüÁÔü┤). Decimal value:
    `21888242871839275222246405745257275088696311157297823662689037894645226208583`. -/
def p : Nat := 36*u^4 + 36*u^3 + 24*u^2 + 6*u + 1

/-- BN254 group order `N = 36uÔü┤ + 36u┬│ + 18u┬▓ + 6u + 1` (the twist
    of `p` ÔÇö differs only in the `u┬▓` coefficient). Decimal value:
    `21888242871839275222246405745257275088548364400416034343698204186575808495617`. -/
def N : Nat := 36*u^4 + 36*u^3 + 18*u^2 + 6*u + 1

/-- `p` is nonzero ÔÇö required for `Fin p`'s numeric-tower instances
    to resolve. The `+ 1` at the tail of the polynomial makes this
    trivial: `p Ôëą 1`. -/
instance : NeZero p := ÔčĘby unfold p; omegaÔčę

/-- Generator `x`-coordinate. -/
def Gx : Nat := 1

/-- Generator `y`-coordinate. -/
def Gy : Nat := 2

/-- Field elements over `F_p`. Type-alias to `Fin p` so BN254
    coordinates are distinct from secp256k1's (accepting a raw
    `Nat` in place of an `Fp` here is a type error). -/
abbrev Fp := Fin p

/-- BN254 `Fp2` ÔÇö the polymorphic tower type pinned to `p`. -/
abbrev Fp2 := _root_.Fp2 p

/-- BN254 `Fp6` ÔÇö pinned. Requires the `SexticNonResidue` instance
    below. -/
abbrev Fp6 := _root_.Fp6 p

/-- BN254 `Fp12` ÔÇö pinned. Same as `Fp6`. -/
abbrev Fp12 := _root_.Fp12 p

/-- BN254 `G2.Point` ÔÇö pinned. -/
abbrev G2Point := EvmSemantics.Crypto.G2.Point p

/-- BN254 GÔéü point over `Fp`. -/
abbrev Point := EvmSemantics.Crypto.EC.Point Fp

/-- The BN254 curve packaged for the generic point operations. -/
def curve : EvmSemantics.Crypto.Weierstrass.Curve p := { b := Fin.ofNat _ 3 }

/-- The BN254 generator point `G = (1, 2)`. -/
def G : Point := .affine (Fin.ofNat _ Gx) (Fin.ofNat _ Gy)

/-- Double a BN254 point. -/
@[inline] def doublePoint (P : Point) : Point :=
  EvmSemantics.Crypto.Weierstrass.doublePoint curve P

/-- Add two BN254 points. -/
@[inline] def addPoint (P Q : Point) : Point :=
  EvmSemantics.Crypto.Weierstrass.addPoint curve P Q

/-- Scalar multiplication on BN254. -/
@[inline] def scalarMul (k : Nat) (P : Point) : Point :=
  EvmSemantics.Crypto.Weierstrass.scalarMul curve k P

/-- Curve-membership check. -/
@[inline] def onCurve (x y : Fp) : Bool :=
  EvmSemantics.Crypto.Weierstrass.onCurve curve x y

/-- BN254's GÔéé twist coefficient `b' = 3 / (9 + u) Ôłł Fp2`
    (D-type twist). -/
def g2TwistB : Fp2 :=
  _root_.Fp2.mulByFp (_root_.Fp2.inv { c0 := 9, c1 := 1 }) 3

/-- BN254's GÔéé curve packaged for the polymorphic `G2.*` ops. -/
def g2Curve : EvmSemantics.Crypto.G2.Curve p := { b := g2TwistB }

end EvmSemantics.Crypto.Bn254

/-- BN254's sextic non-residue is `╬ż = 9 + u Ôłł Fp2`. Multiplication
    by `╬ż` has a fast specialised form:
    `(aÔéÇ + aÔéü┬Ěu) ┬Ě (9 + u) = (9aÔéÇ Ôłĺ aÔéü) + (aÔéÇ + 9aÔéü)┬Ěu`.
    Two constant-multiplications-by-9 + two additions rather than the
    generic Fp2 mul's three base-field muls. -/
@[inline] instance instBn254SexticNonResidue :
    SexticNonResidue EvmSemantics.Crypto.Bn254.p where
  mulByXi a := { c0 := 9 * a.c0 - a.c1, c1 := a.c0 + 9 * a.c1 }
