/-! ## SSWU + isogeny algorithm. -/

/-- Horner evaluation of a polynomial `∑ᵢ kᵢ · x^i` with coeffs
    (constant-first). -/
def hornerEval (coeffs : List Fp) (x : Fp) : Fp :=
  coeffs.foldr (fun c acc => acc * x + c) 0

/-- Sign function `sgn0(a) = a.val mod 2` (RFC 9380 §4.1). -/
@[inline] def sgn0 (a : Fp) : Nat := a.val % 2

/-- Check whether `x` is a quadratic residue in Fp: `sqrt(x)² = x`
    (true for `x = 0` and any nonzero square). -/
def isSquare (x : Fp) : Bool := decide ((sqrt x)^2 = x)

/-- Simplified SSWU map: `Fp → E'` where E' is the isogenous curve.
    Affine (rather than projective) formulation — one field
    inversion per call. -/
def sswuG1 (t : Fp) : Fp × Fp :=
  let t2 := t * t
  let ztsq := isoZ * t2                          -- Z · t²
  let ztsq2 := ztsq * ztsq                       -- Z² · t⁴
  let tv2 := ztsq + ztsq2                        -- Z·t² + Z²·t⁴
  let xDen0 := -isoA * tv2
  let xDen := if xDen0 = 0 then isoZ * isoA else xDen0
  let xNum := isoB * (tv2 + 1)
  let x1 := xNum * xDen⁻¹                        -- first candidate x'
  let gx1 := x1 * x1 * x1 + isoA * x1 + isoB     -- g(x1) = x1³ + A'·x1 + B'
  if isSquare gx1 then
    let y0 := sqrt gx1
    let y := if sgn0 t = sgn0 y0 then y0 else -y0
    (x1, y)
  else
    -- Second candidate: x2 = Z · t² · x1.
    let x2 := ztsq * x1
    let gx2 := x2 * x2 * x2 + isoA * x2 + isoB
    let y0 := sqrt gx2
    let y := if sgn0 t = sgn0 y0 then y0 else -y0
    (x2, y)

/-- 11-isogeny map from E' to BLS12-381 G₁ (E). -/
def isoMapG1 (x' y' : Fp) : Point :=
  let xn := hornerEval kXNum x'
  let xd := hornerEval kXDen x'
  let yn := hornerEval kYNum x'
  let yd := hornerEval kYDen x'
  let x := xn * xd⁻¹
  let y := y' * yn * yd⁻¹
  .affine x y

/-- Full MAP_FP_TO_G1: SSWU + 11-isogeny, then cofactor clearing `[h_eff]·P`
    with `h_eff = 0xd201000000010001` (RFC 9380 §8.8.1). Without this the map
    result need not lie in the prime-order subgroup; EIP-2537's
    `BLS12_MAP_FP_TO_G1` requires a subgroup element. -/
def mapFpToG1 (u : Fp) : Point :=
  let (x', y') := sswuG1 u
  EvmSemantics.Crypto.Bls12381.scalarMul 0xd201000000010001 (isoMapG1 x' y')

/-- Run `0x10 BLS12_MAP_FP_TO_G1`: parse 64-byte input, apply the
    map, encode the 128-byte output. -/
def run? (input : ByteArray) : Option ByteArray := do
  if input.size ≠ fpBytes then none
  else
    let u ← decodeFp input 0
    some (encodePoint (mapFpToG1 u))

end EvmSemantics.Crypto.Bls12381MapFpToG1
